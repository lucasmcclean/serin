#!/bin/sh

if [ -t 1 ]; then
    RED=$(printf '\033[31m')
    GREEN=$(printf '\033[32m')
    YELLOW=$(printf '\033[33m')
    CYAN=$(printf '\033[36m')
    RESET=$(printf '\033[0m')
else
    RED=""
    GREEN=""
    YELLOW=""
    CYAN=""
    RESET=""
fi

STAGED=$(git diff --cached --name-only -- '*.rs')
if [ -z "$STAGED" ]; then
    printf "%sNo files to check%s\n" "$CYAN" "$RESET"
    exit 0
fi

printf "%sChecking code formatting...%s\n" "$YELLOW" "$RESET"

make check || {
    printf "%sERROR: check failed. Aborting commit.%s\n" "$RED" "$RESET" >&2
    exit 1
}

printf "%sAll checks passed%s\n" "$GREEN" "$RESET"
exit 0
